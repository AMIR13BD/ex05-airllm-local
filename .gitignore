# Python env
.venv/
__pycache__/
*.pyc

# AirLLM layer shards + HF model cache + re-sharded copies (huge — never commit)
.airllm_cache/
airllm_cache/
.prepared_models/
hf_cache/
models/

# Secrets — never commit tokens/keys
.env
*.token
HF_TOKEN*
*.key
*.pem
credentials.json

# Logs (verbose; keep the dir, not the contents)
logs/*.log
logs/*.out

# Frozen lock (optional, generated)
requirements.lock.txt
