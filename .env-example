# Copy to .env and fill in. .env is git-ignored and must NEVER be committed.

# Hugging Face — OPTIONAL for Qwen2.5 (public, Apache-2.0). Only needed to avoid
# download throttling or for gated models.
HF_TOKEN=

# Where AirLLM writes per-layer shards (fast NVMe, ~84 GB for the full 14B sweep).
# Defaults to <repo>/.airllm_cache if unset.
AIRLLM_CACHE=

# OPTIONAL — only if you live-query provider pricing for the cost analysis.
# The cost analysis can also run purely from published per-token prices in
# config/cost_config.json, with NO API calls.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
